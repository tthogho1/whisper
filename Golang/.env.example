# Gladia API 設定ファイル
# このファイルを.envとして保存し、実際のAPIキーを設定してください

# Gladia API キー（https://gladia.io/ で取得）
GLADIA_API_KEY=your_gladia_api_key_here

# AWS S3 設定（バッチ処理用）
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_INPUT_BUCKET=your-input-bucket-name
AWS_OUTPUT_BUCKET=your-output-bucket-name

# 並列処理設定
MAX_WORKERS=3

# 使用例:
# 単一ファイル処理:
# 1. 上記のAPIキーを実際の値に変更
# 2. このファイルを .env として保存
# 3. ./gladia-transcribe input.mp4 で実行

# S3バッチ処理:
# 1. 上記のAPIキーとAWS設定をすべて実際の値に変更
# 2. このファイルを .env として保存
# 3. ./gladia-transcribe batch で実行

# 注意:
# - .envファイルはGitにコミットしないでください
# - APIキーとAWS認証情報は秘匿情報です
# - .gitignoreに.envを追加することを推奨